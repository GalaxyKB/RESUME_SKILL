# ==========================================
# RESUME_SKILL .gitignore
# Privacy and security configurations
# ==========================================

# Sensitive information - NEVER commit
.env
.env.local
.env.*.local
*.pem
*.key
*.secret

# Personal data and resumes
personal_info/unified_profile.yaml
personal_info/resume/*
!personal_info/resume/.gitkeep
personal_info/formal_resume/*
!personal_info/formal_resume/.gitkeep
personal_info/general_information/*
!personal_info/general_information/.gitkeep
personal_info/*.pdf

# Output and records
outputs/
logs/
records/
*.log

# Browser sessions and cache (contains login info)
.session/
.cache/
.cookies/

# Application data
data/

# ==========================================
# Development environment
# ==========================================
.venv/
venv/
env/
ENV/

# ==========================================
# Python
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ==========================================
# IDE and editors
# ==========================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.project
.pydevproject
.settings/

# ==========================================
# OS files
# ==========================================
Thumbs.db
.DS_Store
desktop.ini

# ==========================================
# Continue config (not part of this project)
# ==========================================
.continue/

# Temporary files
*.tmp
*.bak
