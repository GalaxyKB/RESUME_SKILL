{
  "$schema": "https://opencode.ai/config.json",
  "skills": {
    "paths": [".opencode/skills"]
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": true
    }
  },
  "permission": {
    "bash": {
      "resume-skill *": "allow",
      "pip install resume-skill": "allow",
      "pip install *": "ask",
      "*": "ask"
    }
  }
}
