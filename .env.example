# ==========================================
# RESUME_SKILL - 环境配置文件模板
# Copy to .env and fill in your actual values
# ==========================================

# ==========================================
# LLM Provider 配置 (必需)
# ==========================================
# 选择 LLM 提供商: deepseek 或 openai
LLM_PROVIDER=deepseek

# 方案1: 使用 DeepSeek API (推荐 - 国内访问稳定，成本低)
# 获取方式: https://www.deepseek.com/ 或 火山引擎
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DEEPSEEK_MODEL=deepseek-v4-pro-260425
DEEPSEEK_ENABLE_WEB_SEARCH=false

# 方案2: 使用 OpenAI API (需要代理)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# ==========================================
# 浏览器配置 (可选)
# ==========================================
# 浏览器类型: chrome 或 chromium
BROWSER_CHANNEL=chrome

# 浏览器可执行文件路径 (通常留空)
# BROWSER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# ==========================================
# 日志和调试 (可选)
# ==========================================
DEBUG_MODE=false
LOG_LEVEL=INFO
