# ==========================================
# RESUME_SKILL - 环境配置文件模板
# Copy to .env and fill in your actual values
# ==========================================

# ==========================================
# LLM API 配置 (必需)
# ==========================================

# 方案1: 使用 DeepSeek API (推荐 - 更便宜)
# 获取方式: https://www.deepseek.com/
# 1. 访问 DeepSeek 官网
# 2. 注册账户并充值
# 3. 创建 API 密钥
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DEEPSEEK_MODEL=deepseek-v4-pro-260425
DEEPSEEK_ENABLE_WEB_SEARCH=false

# 方案2: 使用 OpenAI API
# 获取方式: https://platform.openai.com/
# 1. 创建 OpenAI 账户
# 2. 添加支付信息
# 3. 在 API keys 页面创建密钥
# OPENAI_API_KEY=your_openai_api_key_here

# ==========================================
# 浏览器配置 (可选)
# ==========================================

# 浏览器类型: chrome 或留空使用默认 Chromium
BROWSER_CHANNEL=chrome

# 浏览器可执行文件路径 (通常留空)
# 如果未安装Chrome/Chromium，需要指定路径
# BROWSER_EXECUTABLE_PATH=C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe

# ==========================================
# 日志和调试 (可选)
# ==========================================

# 调试模式: true 或 false
DEBUG_MODE=false

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ==========================================
# 其他配置 (可选)
# ==========================================

# 默认工作模式: interactive (交互) 或 auto (自动)
DEFAULT_MODE=interactive

# 自动截图: true 或 false
SCREENSHOT_ENABLED=true
