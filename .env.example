# ==========================================
# RESUME_SKILL - 环境配置文件模板
# Copy to .env and fill in your actual values
# ==========================================

# ==========================================
# LLM Provider 配置 (必需)
# ==========================================
# 选择 LLM 提供商: ark/doubao/deepseek/openai
LLM_PROVIDER=ark

# 火山 Ark responses API（推荐，文本和视觉统一）
ARK_API_KEY=your_ark_api_key_here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-seed-2-0-lite-260428

# 方案1: 使用 DeepSeek API (推荐 - 国内访问稳定，成本低)
# 获取方式: https://www.deepseek.com/ 或 火山引擎
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DEEPSEEK_MODEL=deepseek-v4-pro-260425
DEEPSEEK_ENABLE_WEB_SEARCH=false

# ==========================================
# 视觉辅助配置（用于复杂控件、填写后验收）
# ==========================================
VISION_ENABLED=true
VISION_PROVIDER=ark_responses
VISION_API_KEY=your_ark_api_key_here
VISION_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VISION_MODEL=doubao-seed-2-1-pro-260628

# 方案2: 使用 OpenAI API (需要代理)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# ==========================================
# 浏览器配置 (可选)
# ==========================================
# 浏览器类型: chrome 或 chromium
BROWSER_CHANNEL=chrome

# 浏览器可执行文件路径 (通常留空)
# BROWSER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# ==========================================
# MCP 配置 (可选增强功能)
# ==========================================
# MCP SDK 模式需要 Python 3.10+ 环境
# 如果留空或注释，将使用 Legacy JSON-RPC 模式
# 设置后，系统会自动检测并使用 MCP SDK 模式
# MCP_PYTHON_PATH=C:\Users\YourName\anaconda3\envs\resume-skill-mcp\python.exe

# ==========================================
# 日志和调试 (可选)
# ==========================================
DEBUG_MODE=false
LOG_LEVEL=INFO
